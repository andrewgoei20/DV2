{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
"height": 450,
"projection": {
  "type": "equalEarth",
  "scale": 132,
  "translate": [250, 238]
},
  "layer": [
    {
      "data": {
        "url": "data/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e7e2db",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      }
    },
    {
      "data": {
        "url": "data/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {
          "lookup": "id",
          "from": {
            "data": {
              "url": "data/ao_country_titles_map.csv",
              "format": {
                "type": "csv",
                "parse": {
                  "id": "number",
                  "titles": "number"
                }
              }
            },
            "key": "id",
            "fields": ["country", "titles"]
          }
        },
        {
          "calculate": "isValid(datum.titles) ? datum.titles : 0",
          "as": "titles_fixed"
        },
        {
          "filter": "datum.titles_fixed > 0"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "titles_fixed",
          "type": "quantitative",
          "scale": {
            "type": "sqrt",
            "domain": [1, 80],
            "range": ["#b9dde0", "#0f6f67"]
          },
          "legend": {
  "title": "Singles titles",
  "orient": "none",
  "legendX": 540,
  "legendY": 36,
  "gradientLength": 140
}
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "titles_fixed",
            "type": "quantitative",
            "title": "Singles titles"
          }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "country": "Australia",
            "titles": 80,
            "lon": 134,
            "lat": -25,
            "dx": 16,
            "dy": -10
          },
          {
            "country": "United States",
            "titles": 43,
            "lon": -98,
            "lat": 39,
            "dx": 16,
            "dy": -8
          }
        ]
      },
      "mark": {
        "type": "circle",
        "size": 80,
        "filled": true,
        "color": "#fffdf9",
        "stroke": "#0f5c4d",
        "strokeWidth": 2
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" }
      }
    },
    {
      "data": {
        "values": [
          {
            "label": "Australia (80)",
            "lon": 134,
            "lat": -25,
            "dx": 16,
            "dy": -10
          },
          {
            "label": "United States (43)",
            "lon": -98,
            "lat": 39,
            "dx": 16,
            "dy": -8
          }
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#1f1d1a"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "text": { "field": "label" },
        "xOffset": { "field": "dx", "type": "quantitative" },
        "yOffset": { "field": "dy", "type": "quantitative" }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    }
  }
}
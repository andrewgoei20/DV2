            "format": {
              "type": "csv",
              "parse": { "era_order": "number", "square": "number", "row": "number", "col": "number", "is_top3": "number", "top3_pct": "number" }
            }
          },
          "transform": [
            { "filter": "datum.era === 'Pre-Open'" },
            { "calculate": "datum.is_top3 == 1 ? 'Top 3 countries' : 'Other countries'", "as": "group_label" }
          ],

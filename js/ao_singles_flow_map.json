{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 450,
  "background": "#fffdf9",
  "padding": { "left": 10, "right": 10, "top": 5, "bottom": 10 },

  "projection": {
    "type": "equalEarth",
    "scale": 132,
    "translate": [270, 255]
  },

  "layer": [
    {
      "data": {
        "url": "data/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#efe8de",
        "stroke": "#ffffff",
        "strokeWidth": 0.8
      }
    },

    {
      "data": {
        "url": "data/ao_singles_flow_curves.csv",
        "format": {
          "type": "csv",
          "parse": {
            "step": "number",
            "lon": "number",
            "lat": "number",
            "total_entries": "number"
          }
        }
      },
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "stroke": "#79b6b3",
        "strokeOpacity": 0.42,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "detail": { "field": "flow_id", "type": "nominal" },
        "order": { "field": "step", "type": "quantitative" },
        "size": {
          "field": "total_entries",
          "type": "quantitative",
          "scale": {
            "domain": [1, 30],
            "range": [1.2, 7]
          },
          "legend": null
        }
      }
    },

    {
      "data": {
        "url": "data/ao_singles_flow_curves.csv",
        "format": {
          "type": "csv",
          "parse": {
            "step": "number",
            "lon": "number",
            "lat": "number",
            "total_entries": "number"
          }
        }
      },
      "transform": [
        {
          "lookup": "country",
          "from": {
            "data": {
              "url": "data/ao_men_women_singles_entries.csv",
              "format": {
                "type": "csv",
                "parse": {
                  "men_singles": "number",
                  "women_singles": "number",
                  "total_entries": "number"
                }
              }
            },
            "key": "country",
            "fields": ["men_singles", "women_singles"]
          }
        }
      ],
      "mark": {
        "type": "line",
        "interpolate": "monotone",
        "stroke": "#000000",
        "strokeOpacity": 0.001,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "detail": { "field": "flow_id", "type": "nominal" },
        "order": { "field": "step", "type": "quantitative" },
        "size": {
          "field": "total_entries",
          "type": "quantitative",
          "scale": {
            "domain": [1, 30],
            "range": [16, 34]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "country", "type": "nominal", "title": "Country" },
          { "field": "men_singles", "type": "quantitative", "title": "Men's singles" },
          { "field": "women_singles", "type": "quantitative", "title": "Women's singles" },
          { "field": "total_entries", "type": "quantitative", "title": "Total entries" }
        ]
      }
    },

    {
      "data": {
        "url": "data/ao_men_women_singles_entries.csv",
        "format": {
          "type": "csv",
          "parse": {
            "men_singles": "number",
            "women_singles": "number",
            "total_entries": "number",
            "lat": "number",
            "lon": "number"
          }
        }
      },
      "transform": [
        { "filter": "datum.total_entries > 0" }
      ],
      "mark": {
        "type": "circle",
        "filled": true,
        "fill": "#79b6b3",
        "stroke": "#ffffff",
        "strokeWidth": 1.2,
        "opacity": 0.9
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "size": {
          "field": "total_entries",
          "type": "quantitative",
          "scale": {
            "domain": [1, 30],
            "range": [60, 1200]
          },
          "legend": {
            "title": "Singles entries",
            "orient": "top-left",
            "values": [5, 15, 30],
            "symbolType": "circle",
            "symbolSize": 1400,
            "symbolStrokeColor": "#5f9f99",
            "symbolFillColor": "#79b6b3",
            "labelColor": "#1f1d1a",
            "titleColor": "#1f1d1a",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "offset": 8
          }
        },
        "tooltip": [
          { "field": "country", "type": "nominal", "title": "Country" },
          { "field": "men_singles", "type": "quantitative", "title": "Men's singles" },
          { "field": "women_singles", "type": "quantitative", "title": "Women's singles" },
          { "field": "total_entries", "type": "quantitative", "title": "Total entries" }
        ]
      }
    },

    {
      "data": {
        "values": [
          { "place": "Melbourne", "lon": 144.9631, "lat": -37.8136 }
        ]
      },
      "mark": {
        "type": "point",
        "shape": "diamond",
        "filled": true,
        "size": 220,
        "color": "#b23a2f",
        "stroke": "#ffffff",
        "strokeWidth": 1.4
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "tooltip": [
          { "field": "place", "type": "nominal", "title": "Destination" }
        ]
      }
    },

    {
      "data": {
        "values": [
          { "country": "United States", "lon": -98, "lat": 35, "dx": 0, "dy": -14 },
          { "country": "France", "lon": -10, "lat": 48, "dx": 0, "dy": -12 },
          { "country": "China", "lon": 104, "lat": 40, "dx": 0, "dy": -12 },
          { "country": "Australia", "lon": 147, "lat": -25, "dx": 12, "dy": -8 },
          { "country": "Melbourne", "lon": 144.9631, "lat": -37.8136, "dx": 14, "dy": 10 }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "baseline": "middle"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "text": { "field": "country" },
        "xOffset": { "field": "dx", "type": "quantitative" },
        "yOffset": { "field": "dy", "type": "quantitative" },
        "color": {
          "condition": {
            "test": "datum.country == 'Melbourne'",
            "value": "#b23a2f"
          },
          "value": "#1f1d1a"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter"
    }
  }
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 360,
  "height": 320,
  "title": {
    "text": "Top countries by Australian Open singles titles",
    "fontSize": 18,
    "anchor": "start",
    "offset": 12
  },
  "data": {
    "url": "data/country_titles.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 5,
    "color": "#0f5c4d"
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": "-x",
      "title": null,
      "axis": {
        "labelFontSize": 12
      }
    },
    "x": {
      "field": "titles",
      "type": "quantitative",
      "title": "Singles titles",
      "axis": {
        "labelFontSize": 12,
        "titleFontSize": 13,
        "grid": false
      }
    },
    "tooltip": [
      { "field": "country", "type": "nominal", "title": "Country" },
      { "field": "titles", "type": "quantitative", "title": "Titles" }
    ]
  },
  "config": {
    "background": "#fffdf9",
    "view": {
      "stroke": null
    }
  }
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#fffdf9",
  "width": 530,
  "height": 550,
  "padding": 2,

  "data": {
    "url": "data/ao_region_era_radial.csv",
    "format": {
      "type": "csv",
      "parse": {
        "era_order": "number",
        "titles": "number"
      }
    }
  },

  "transform": [
    {
      "joinaggregate": [
        { "op": "sum", "field": "titles", "as": "era_total" }
      ],
      "groupby": ["era", "era_order"]
    },
    {
      "calculate": "datum.titles / datum.era_total",
      "as": "share"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 55,
        "stroke": "#fffdf9",
        "strokeWidth": 2
      },
      "encoding": {
        "theta": {
          "field": "era_order",
          "type": "ordinal"
        },
        "radius": {
          "field": "share",
          "type": "quantitative",
          "stack": true,
          "scale": {
            "type": "sqrt",
            "domain": [0, 1],
            "range": [55, 240]
          }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "scale": {
            "domain": ["Oceania", "Americas", "Europe", "Asia"],
            "range": ["#0f5c4d", "#4c9fb3", "#e0a13b", "#d96b4d"]
          },
          "legend": {
            "title": "Region"
          }
        },
        "tooltip": [
          { "field": "era", "type": "nominal", "title": "Era" },
          { "field": "region", "type": "nominal", "title": "Region" },
          { "field": "titles", "type": "quantitative", "title": "Titles" },
          { "field": "share", "type": "quantitative", "title": "Share", "format": ".0%" }
        ]
      }
    },
    {
      "data": {
        "values": [
          { "x": 299, "y": 300, "label": "Pre-Open" },
          { "x": 326, "y": 84, "label": "1970s–1980s" },
          { "x": 24, "y": 80, "label": "1990s–2000s" },
          { "x": 55, "y": 301, "label": "2010s–2026" }
        ]
      },
      "mark": {
        "type": "text",
        "font": "Inter",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#1f1d1a",
        "align": "center",
        "baseline": "middle"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "axis": null },
        "y": { "field": "y", "type": "quantitative", "axis": null },
        "text": { "field": "label" }
      }
    }
  ],

  "config": {
    "view": { "stroke": null }
  }
}